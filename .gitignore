# ===============================
# FAMILY PLUS - Django .gitignore
# ===============================

# --- Python / Django ---
__pycache__/
*.py[cod]
*$py.class
*.pyo

# --- Django Specific ---
db.sqlite3
*.log
*.pot
*.pyc
*.mo
*.swp
.DS_Store

# --- Environment & Secrets ---
.env
*.env
secrets.json
config.json

# --- Virtual Environments ---
venv/
env/
ENV/
.virtualenv/
*.venv/
pip-log.txt
pip-delete-this-directory.txt

# --- Static / Media (collected or generated) ---
staticfiles/
static_root/
media/
media_root/
familyplus/staticfiles/
familyplus/media/
*.collectstatic

# --- Build & Packaging ---
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# --- IDE / Editor files ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# --- OS generated files ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
Icon?
._*

# --- Logs & Coverage ---
*.log
log/
logs/
*.cover
.coverage
htmlcov/
.tox/
.nox/
.coverage.*
.cache/
pytest_cache/
nosetests.xml
coverage.xml
*.coveragerc

# --- Migrations (optional, uncomment if you regenerate often) ---
# **/migrations/*
# !**/migrations/__init__.py

# --- Backup & Temp Files ---
*.bak
*.tmp
*.temp
*.old
*.orig
*.save
*.swp
*.swo

# --- Jupyter / Notebooks (if ever used) ---
.ipynb_checkpoints/

# --- Node / Frontend (if using npm/yarn for frontend assets) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
